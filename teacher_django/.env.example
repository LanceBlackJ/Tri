# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Xunfei Spark API Credentials
XUNFEI_APPID=your_appid_here
XUNFEI_API_KEY=your_api_key_here
