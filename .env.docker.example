# ============================================================
# docker-compose 环境变量模板。
# 用法：复制为 .env.docker，把所有「改成...」填成真实值。
# .env.docker 含密码，已被 .gitignore 忽略，不会进库。
# ============================================================

# ---- MySQL 容器初始化（仅首次创建 mysql_data 卷时生效）----
MYSQL_ROOT_PASSWORD=改成强root密码
MYSQL_DATABASE=tri
MYSQL_USER=lance
MYSQL_PASSWORD=改成强密码

# ---- Django 连接数据库（要与上面的 MySQL 用户/库一致）----
DB_ENGINE=mysql
DB_NAME=tri
DB_USER=lance
DB_PASSWORD=改成强密码
# DB_HOST / DB_PORT 由 docker-compose 注入（db:3306），此处无需填

# ---- Django 基本配置 ----
DEBUG=False
# 生成一串随机 key，例如：python -c "import secrets;print(secrets.token_urlsafe(50))"
SECRET_KEY=改成一串随机长字符串
# 必须包含服务器公网 IP，否则 DEBUG=False 下会 400 Bad Request
ALLOWED_HOSTS=8.145.62.165,localhost,127.0.0.1

# ---- gunicorn 调优（可选，用默认即可）----
GUNICORN_WORKERS=3
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=600

# ---- Celery / Redis（可选）----
# CELERY_BROKER_URL / CELERY_RESULT_BACKEND / SERVICE_ROLE 已由 docker-compose.yml
# 的 environment 直接注入（redis://redis:6379/...），此处无需填。
# CELERY_CONCURRENCY：worker 容器的并发数（默认 2，和远程 GPU 的生成并发量级匹配，
# 避免同时打爆 GPU 实例；需要更大吞吐时可调大，但要同步确认 GPU 侧扛得住）。
CELERY_CONCURRENCY=2
# USE_CELERY_FOR_PPTX_EXPORT：PPTX 导出是否也走 Celery 队列（默认 false，走后台线程即可；
# 部署到 Docker、想让导出也受 worker 统一管理时可设为 true）。
USE_CELERY_FOR_PPTX_EXPORT=true

# ---- AI 模型（远程 GPU Ollama / 讯飞星火）----
# 直接从你当前的 teacher_django/.env 复制这几项的值过来：
XUNFEI_API_URL=改成你的模型地址
XUNFEI_MODEL=改成模型名
XUNFEI_API_KEY=改成你的key
XUNFEI_TIMEOUT=600
XINGHUO_MAX_CONCURRENCY=2
GENERATION_RESOURCE_CONCURRENCY=3
